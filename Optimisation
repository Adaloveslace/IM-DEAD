import time
import functools
import concurrent.futures
import numpy as np
import torch
import torch.nn as nn
import torch.nn.utils.prune as prune


def get_optimal_device():
    if torch.cuda.is_available():
        device = torch.device("cuda")
    elif torch.backends.mps.is_available():
        # Apple Silicon GPU acceleration
        device = torch.device("mps")
    else:
        device = torch.device("cpu")
    return device


@functools.lru_cache(maxsize=128)
def cached_detrend_computation(tic_id, time_array_bytes, flux_array_bytes):
   
    time_arr = np.frombuffer(time_array_bytes, dtype=np.float64)
    flux_arr = np.frombuffer(flux_array_bytes, dtype=np.float64)
    
    time.sleep(0.1) 
    median_val = np.median(flux_arr)
    detrended = flux_arr - (0.01 * np.sin(time_arr))
    return (detrended / median_val).tobytes()

class ProductionCNN(nn.Module):
    def __init__(self, seq_len=200):
        super(ProductionCNN, self).__init__()
        self.conv = nn.Conv1d(1, 16, kernel_size=5, padding=2)
        self.fc = nn.Linear(16 * seq_len, 1)

    def forward(self, x):
        x = torch.relu(self.conv(x))
        x = x.view(x.size(0), -1)
        return torch.sigmoid(self.fc(x))

def apply_model_compression(model, seq_len=200):

    prune.l1_unstructured(model.conv, name="weight", amount=0.30)
    prune.remove(model.conv, "weight")
    
   
    quantized_model = torch.quantization.quantize_dynamic(
        model, 
        {nn.Linear}, 
        dtype=torch.qint8
    )
    return quantized_model

def preprocess_single_curve(star_id):
   
    np.random.seed(star_id)
    raw_time = np.linspace(0, 10, 1000)
    raw_flux = np.ones(1000) + np.random.normal(0, 0.01, 1000)
    
   
    time_bytes = raw_time.tobytes()
    flux_bytes = raw_flux.tobytes()
    
 
    processed_bytes = cached_detrend_computation(star_id, time_bytes, flux_bytes)
    processed_flux = np.frombuffer(processed_bytes, dtype=np.float64)
  
    standard_subset = processed_flux[:200]
    return standard_subset

def process_light_curve_batch_concurrently(star_ids):
   
    with concurrent.futures.ThreadPoolExecutor() as executor:
        results = list(executor.map(preprocess_single_curve, star_ids))
    return np.array(results)


if __name__ == "__main__":
    device = get_optimal_device()
    print(f"[SYSTEM] Optimal active processing hardware detected: {device}")

   
    target_tic_ids = list(range(10001, 10065))
    seq_len = 200

  
    start_time = time.time()
    preprocessed_batch = process_light_curve_batch_concurrently(target_tic_ids)
    preprocess_duration = time.time() - start_time
    print(f"[BATCH] Preprocessed {len(target_tic_ids)} light curves in {preprocess_duration:.4f} seconds.")

   
    start_time = time.time()
    _ = process_light_curve_batch_concurrently(target_tic_ids)
    recached_duration = time.time() - start_time
    print(f"[CACHE] Re-processing batch using cache: {recached_duration:.4f} seconds.")

  
    production_model = ProductionCNN(seq_len=seq_len).to(device)
    production_model.eval()
  
    batch_tensor = torch.tensor(preprocessed_batch, dtype=torch.float32).unsqueeze(1).to(device)

    start_time = time.time()
    with torch.no_grad():
        baseline_predictions = production_model(batch_tensor)
    baseline_duration = time.time() - start_time
    print(f"[INFERENCE] Raw model batch inference duration: {baseline_duration:.6f} seconds.")

    cpu_model = ProductionCNN(seq_len=seq_len)
    compressed_model = apply_model_compression(cpu_model, seq_len=seq_len)
    
    cpu_batch_tensor = torch.tensor(preprocessed_batch, dtype=torch.float32).unsqueeze(1)
    start_time = time.time()
    with torch.no_grad():
        quantized_predictions = compressed_model(cpu_batch_tensor)
    quantized_duration = time.time() - start_time
    print(f"[COMPRESSION] Quantized model batch CPU inference duration: {quantized_duration:.6f} seconds.")
