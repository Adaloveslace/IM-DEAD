import json
import numpy as np
from scipy.signal import savgol_filter
from scipy.stats import skew, kurtosis
from astropy.timeseries import BoxLeastSquares
from astropy.stats import sigma_clip

def generate_synthetic_star_system():
    np.random.seed(101)
    time = np.linspace(0, 15, 3000)
    baseline = 1.0
    stellar_activity = 0.008 * np.sin(2 * np.pi * time / 12.0)
    noise = np.random.normal(0, 0.002, size=len(time))
    
    true_period = 3.5
    true_epoch = 1.0
    true_depth = 0.006
    true_duration = 0.12
    
    transit_signal = np.zeros_like(time)
    for i, t in enumerate(time):
        phase_offset = (t - true_epoch) % true_period
        if phase_offset < (true_duration / 2.0) or phase_offset > (true_period - (true_duration / 2.0)):
            transit_signal[i] = -true_depth
            
    raw_flux = baseline + stellar_activity + transit_signal + noise
    
    raw_flux[150] = 1.15
    raw_flux[1500] = 0.85
    
    return time, raw_flux, {
        "true_period": true_period,
        "true_epoch": true_epoch,
        "true_depth": true_depth,
        "true_duration": true_duration,
        "stellar_rotation": 12.0,
        "r_star": 1.1,
        "m_star": 1.05
    }

def preprocess_and_detrend(time, flux, window_length=151, polyorder=2):
    clipped_flux = sigma_clip(flux, sigma=3.0, maxiters=5, masked=True)
    mask = ~clipped_flux.mask
    clean_time = time[mask]
    clean_flux = flux[mask]
    
    if window_length % 2 == 0:
        window_length += 1
    trend = savgol_filter(clean_flux, window_length, polyorder)
    detrended_flux = clean_flux - trend + np.median(clean_flux)
    
    return clean_time, detrended_flux

def extract_statistical_features(flux):
    return {
        "mean": float(np.mean(flux)),
        "std": float(np.std(flux)),
        "skewness": float(skew(flux)),
        "kurtosis": float(kurtosis(flux))
    }

def run_transit_search(time, flux, min_p=1.0, max_p=10.0, grid_steps=3000):
    bls = BoxLeastSquares(time, flux)
    periods = np.linspace(min_p, max_p, grid_steps)
    durations = np.linspace(0.04, 0.2, 5)
    
    periodogram = bls.power(periods, durations)
    best_idx = np.argmax(periodogram.power)
    
    det_period = periodogram.period[best_idx]
    det_epoch = periodogram.transit_time[best_idx]
    det_duration = periodogram.duration[best_idx]
    
    mean_power = np.mean(periodogram.power)
    std_power = np.std(periodogram.power)
    sde = (periodogram.power[best_idx] - mean_power) / std_power
    
    stats = bls.compute_stats(det_period, det_duration, det_epoch)
    det_depth = stats['depth'][0]
    depth_err = stats['depth'][1]
    snr = det_depth / depth_err if depth_err > 0 else 0.0
    
    phase = ((time - det_epoch) % det_period) / det_period
    phase = np.where(phase > 0.5, phase - 1.0, phase)
    sort_idx = np.argsort(phase)
    
    return {
        "period": float(det_period),
        "epoch": float(det_epoch),
        "duration": float(det_duration),
        "depth": float(det_depth),
        "sde": float(sde),
        "snr": float(snr),
        "folded_phase": phase[sort_idx],
        "folded_flux": flux[sort_idx]
    }

def mock_dl_inference(features):
    score = 0.1
    if features["skewness"] < -0.5:
        score += 0.4
    if features["kurtosis"] > 1.5:
        score += 0.45
    return float(min(0.99, max(0.01, score)))

def check_odd_even_mismatch(time, flux, period, epoch, duration):
    midpoints = np.round((time - epoch) / period)
    in_transit = np.abs((time - epoch) - midpoints * period) < (duration / 2.0)
    
    odd_depths = []
    even_depths = []
    
    for idx in np.unique(midpoints):
        mask = (midpoints == idx) & in_transit
        if not np.any(mask):
            continue
        local_baseline = np.median(flux[~in_transit])
        depth = local_baseline - np.mean(flux[mask])
        if idx % 2 == 1:
            odd_depths.append(depth)
        else:
            even_depths.append(depth)
            
    if len(odd_depths) == 0 or len(even_depths) == 0:
        return 0.0
    mean_odd = np.mean(odd_depths)
    mean_even = np.mean(even_depths)
    
    if (mean_odd + mean_even) <= 0:
        return 0.0
    return float(np.abs(mean_odd - mean_even) / (0.5 * (mean_odd + mean_even)))

def evaluate_transit_geometry(folded_phase, folded_flux, duration, period):
    phase_days = folded_phase * period
    core_mask = np.abs(phase_days) < (duration * 0.2)
    wing_mask = (np.abs(phase_days) >= (duration * 0.2)) & (np.abs(phase_days) <= (duration * 0.5))
    
    if not np.any(core_mask) or not np.any(wing_mask):
        return 0.5
        
    baseline = np.median(folded_flux[np.abs(phase_days) > (duration * 0.6)])
    core_depth = baseline - np.mean(folded_flux[core_mask])
    wing_depth = baseline - np.mean(folded_flux[wing_mask])
    
    if core_depth <= 0:
        return 1.0
        
    return float(wing_depth / core_depth)

def run_diagnostic_vetting(time, flux, search_results, stellar_rotation):
    flags = []
    vet_score = 100.0
    
    odd_even_diff = check_odd_even_mismatch(
        time, flux, search_results["period"], search_results["epoch"], search_results["duration"]
    )
    if odd_even_diff > 0.25:
        flags.append(f"Odd-Even depth mismatch ({odd_even_diff:.1%}) - Suspected Eclipsing Binary")
        vet_score -= 35.0
        
    shape_ratio = evaluate_transit_geometry(
        search_results["folded_phase"], search_results["folded_flux"], search_results["duration"], search_results["period"]
    )
    if shape_ratio > 0.75:
        flags.append(f"V-shaped profile (ratio: {shape_ratio:.2f}) - Suspected Stellar Companion")
        vet_score -= 25.0
        
    for h in [0.5, 1.0, 2.0]:
        if np.abs(search_results["period"] - h * stellar_rotation) / (h * stellar_rotation) < 0.05:
            flags.append(f"Period match with stellar rotation harmonic ({stellar_rotation}d)")
            vet_score -= 30.0
            break
            
    is_valid = len(flags) == 0 and vet_score >= 60.0
    
    return {
        "passed_vetting": bool(is_valid),
        "vetting_score": float(max(0.0, vet_score)),
        "flags": flags if flags else ["Passed all diagnostics"]
    }

def estimate_physical_parameters(period, duration, depth, r_star, m_star):
    G = 6.67430e-11
    M_sun = 1.98847e30
    R_sun = 6.95700e8
    R_earth = 6.3781e6
    AU = 1.495978707e11
    
    r_ratio = np.sqrt(depth)
    r_planet_earth = (r_ratio * r_star * R_sun) / R_earth
    
    period_sec = period * 24.0 * 3600.0
    m_star_kg = m_star * M_sun
    a_m = ( (G * m_star_kg * (period_sec**2)) / (4 * (np.pi**2)) ) ** (1.0/3.0)
    a_au = a_m / AU
    
    r_star_m = r_star * R_sun
    duration_sec = duration * 24.0 * 3600.0
    b_sq = (1.0 + r_ratio)**2 - (a_m / r_star_m)**2 * (np.sin(duration_sec * np.pi / period_sec))**2
    b = np.sqrt(max(0.0, b_sq))
    
    if b > 1.0: 
        b = 0.99
    cos_i = b * (r_star_m / a_m)
    inclination_deg = np.degrees(np.arccos(cos_i))
    
    return {
        "planet_radius_earth": float(r_planet_earth),
        "semi_major_axis_au": float(a_au),
        "impact_parameter": float(b),
        "inclination_deg": float(inclination_deg)
    }

def run_end_to_end_pipeline():
    print("[PIPELINE] Initializing End-to-End Pipeline...")
    
    # Stage 1: Data Loading
    time, raw_flux, system_meta = generate_synthetic_star_system()
    print(f"--> Stage 1 Complete: Loaded {len(time)} observation cadences.")
    
    # Stage 2: Preprocessing & Detrending
    clean_time, detrended_flux = preprocess_and_detrend(time, raw_flux)
    print(f"--> Stage 2 Complete: Filtered outliers. Processed dataset size: {len(clean_time)}")
    
    # Stage 3: Feature Extraction
    features = extract_statistical_features(detrended_flux)
    print(f"--> Stage 3 Complete: Extracted stats (Skewness: {features['skewness']:.4f})")
    
    # Stage 4: Model Inference
    dl_score = mock_dl_inference(features)
    print(f"--> Stage 4 Complete: ML Classifier transit probability score: {dl_score:.2%}")
    
    # Stage 5: Transit Detection (BLS Search)
    detection = run_transit_search(clean_time, detrended_flux)
    print(f"--> Stage 5 Complete: Detected period of {detection['period']:.4f} days with SDE: {detection['sde']:.2f}")
    
    # Stage 6: Post-processing & Vetting
    vetting = run_diagnostic_vetting(clean_time, detrended_flux, detection, system_meta["stellar_rotation"])
    physical_props = estimate_physical_parameters(
        detection["period"], detection["duration"], detection["depth"], 
        system_meta["r_star"], system_meta["m_star"]
    )
    print(f"--> Stage 6 Complete: Physical properties computed and vetted.")
    
    # Stage 7: Results Integration & Formatting
    pipeline_report = {
        "target_stellar_properties": {
            "stellar_radius_solar": system_meta["r_star"],
            "stellar_mass_solar": system_meta["m_star"],
            "rotation_period_days": system_meta["stellar_rotation"]
        },
        "signal_detection_metrics": {
            "period_days": detection["period"],
            "epoch_days": detection["epoch"],
            "duration_days": detection["duration"],
            "transit_depth_fraction": detection["depth"],
            "sde_score": detection["sde"],
            "snr": detection["snr"]
        },
        "classifier_evaluation": {
            "ai_transit_probability": dl_score,
            "vetting_score": vetting["vetting_score"],
            "passed_filters": vetting["passed_vetting"],
            "vetting_remarks": vetting["flags"]
        },
        "derived_planetary_parameters": {
            "planet_radius_earth": physical_props["planet_radius_earth"],
            "semi_major_axis_au": physical_props["semi_major_axis_au"],
            "orbital_inclination_deg": physical_props["inclination_deg"],
            "impact_parameter": physical_props["impact_parameter"]
        }
    }
    
    return pipeline_report

if __name__ == "__main__":
    final_output = run_end_to_end_pipeline()
    print("\n" + "="*50)
    print("FINAL INTEGRATED PIPELINE REPORT (JSON)")
    print("="*50)
    print(json.dumps(final_output, indent=4))
